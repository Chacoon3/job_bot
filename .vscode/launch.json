{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (Uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "job_bot.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8080",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "jinja": true,
      "justMyCode": true
    }
  ]
}
